  "issues": [
    {
      "stable_id": "routing-self-diagnosis__90f948",
      "display_number": "ISSUE-001",
      "title": "用户可能不知道自己是否注册过万豪，却必须先选开通还是绑定",
      "category": "scenario and fit",
      "severity": "high",
      "confidence": "high",
      "status": "active",
      "evidence_ids": [
        "ev_route_entry",
        "ev_failure_recovery",
        "ev_root_screenshot"
      ],
      "problem_summary": "首屏分流要求用户先判断自己是否已有万豪会员，错选结果在失败页才暴露。",
      "impact_summary": "系统应承担的判路成本被转嫁给用户，导致错选、回退与重试。",
      "recommendation_summary": "改为系统辅助判路，或至少把双分流改成带适用条件与损失说明的对比卡片。",
      "discussion_prompts": [
        "授权后系统能不能直接判断用户该走开通还是绑定？",
        "如果做不到，还有什么比“是否已有万豪会员卡”更可靠、也更接近用户已知事实的提问？"
      ]
    },
    {
      "stable_id": "agreement-density__447d2a",
      "display_number": "ISSUE-002",
      "title": "协议页把必选授权和营销偏好混在一起，用户很难一眼分清",
      "category": "cognitive and operational cost",
      "severity": "high",
      "confidence": "high",
      "status": "active",
      "evidence_ids": [
        "ev_agreement"
      ],
      "problem_summary": "必选法务与可选营销处于同一阅读层级，用户必须自行拆分优先级。",
      "impact_summary": "关键法务确认与可选营销授权混读，增加疲劳与不信任。",
      "recommendation_summary": "把必选协议单独聚合，可选营销降级或后置到成功后。",
      "discussion_prompts": [
        "营销授权必须放在主链路里吗？",
        "能不能在成功后再补问这些可选偏好？"
      ]
    },
    {
      "stable_id": "recovery-cta-generic__4dfab6",
      "display_number": "ISSUE-003",
      "title": "失败后要重新做决定，但主按钮还是含糊的“下一步”",
      "category": "foundational experience checks",
      "severity": "high",
      "confidence": "high",
      "status": "active",
      "evidence_ids": [
        "ev_failure_recovery"
      ],
      "problem_summary": "失败页让用户二选一，但按钮文案没有表达实际后果。",
      "impact_summary": "用户在最需要确定性的节点仍然不知道点击后会发生什么。",
      "recommendation_summary": "让按钮文案直接绑定当前分支，或改成两枚明确动作按钮。",
      "discussion_prompts": [
        "如果用户不主动切换选项，系统默认应该把他带去哪里？",
        "比起卡片切换后再点一个通用按钮，直接给两个明确动作按钮会不会更清楚？"
      ]
    },
    {
      "stable_id": "external-jump-trust__7ed0dc",
      "display_number": "ISSUE-004",
      "title": "要跳去万豪登录了，页面却没把会不会返回和是否安全讲清楚",
      "category": "user mental models and habits",
      "severity": "high",
      "confidence": "high",
      "status": "active",
      "evidence_ids": [
        "ev_external_jump"
      ],
      "problem_summary": "页面解释了步骤，但没有解释为什么安全、会不会自动返回、失败后怎么办。",
      "impact_summary": "用户被要求离开当前环境，却得不到足够的信任与回流预期。",
      "recommendation_summary": "补齐信任说明、回流承诺与真实截图，而不是占位图和泛步骤说明。",
      "discussion_prompts": [
        "外跳后到底是自动回流、手动返回，还是刷新后才能看到结果？",
        "用户离开飞猪之前，产品最多能给出什么级别的回流承诺？"
      ]
    },
    {
      "stable_id": "success-followthrough__3933a5",
      "display_number": "ISSUE-005",
      "title": "成功页宣布了结果，但没有把下一步价值接住",
      "category": "problem and value",
      "severity": "medium",
      "confidence": "high",
      "status": "active",
      "evidence_ids": [
        "ev_success_state"
      ],
      "problem_summary": "成功态强调庆祝，但没有给出清晰的后续价值承接动作。",
      "impact_summary": "最高动机时刻没有被转成下一步价值，容易丢失后续 engagement。",
      "recommendation_summary": "把成功页改成价值交接页，明确下一站去向与收益。",
      "discussion_prompts": [
        "成功后最应该把用户带去哪里：会员中心、权益说明，还是会籍结果页？",
        "确认按钮能不能直接代表一个明确去向，而不是只写“确认”？"
      ]
    },
    {
      "stable_id": "identity-mismatch-guidance__412408",
      "display_number": "ISSUE-006",
      "title": "发现实名不一致时，页面没有告诉用户下一步怎么办",
      "category": "foundational experience checks",
      "severity": "medium",
      "confidence": "high",
      "status": "active",
      "evidence_ids": [
        "ev_bind_identity"
      ],
      "problem_summary": "实名确认给出了当前结果，但没有给出不一致时的可见恢复路径。",
      "impact_summary": "一旦用户发现不一致，会停在“看见问题但不知道怎么解决”的状态。",
      "recommendation_summary": "显式提供修改、申诉或客服兜底路径，而不是只展示结果。",
